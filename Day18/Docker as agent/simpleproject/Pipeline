pipeline {
    agent {
        docker {
            image 'ubuntu:22.04'
            args '-u root'
        }
    }

    stages {

        stage('Install Tools') {
            steps {
                sh 'apt update'
                sh 'apt install git -y'
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/rohityt0dev/docker-as-agent.git'
            }
        }

        stage('Run Build') {
            steps {
                sh 'chmod +x app.sh'
                sh './app.sh'
            }
        }

    }
}
